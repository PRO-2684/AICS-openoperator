#include <bang.h>
#include <cnrt.h>
#include <cstdio>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

#define E0 4000000
#define E1 131072
#define E2 32

__mlu_entry__ void k0(half *__restrict__ x) {
  __nram__ half a[E1];
  for (int p = taskId * E1; p < E0; p += E1 * E2) {
    int n = E0 - p;
    if (n > E1) {
      n = E1;
    }
    int m = (n + 63) & ~63;
    __memcpy(a, x + p, n * sizeof(half), GDRAM2NRAM);
    __bang_write_value(a + n, m - n, (half)0.0f);
    __bang_active_gelu(a, a, m);
    __memcpy(x + p, a, n * sizeof(half), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor x) {
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t dim = {E2, 1, 1};
  cnrtNotifier_t s = nullptr;
  cnrtNotifier_t e = nullptr;
  cnrtNotifierCreate(&s);
  cnrtNotifierCreate(&e);
  cnrtPlaceNotifier(s, queue);
  k0<<<dim, cnrtFuncTypeBlock, queue>>>(
      reinterpret_cast<half *>(x.unsafeGetTensorImpl()->mutable_data()));
  cnrtPlaceNotifier(e, queue);
  cnrtQueueSync(queue);
  float us = 0.0f;
  cnrtNotifierDuration(s, e, &us);
  std::fprintf(stderr, "NOTIFY_US %.3f\n", us);
  cnrtNotifierDestroy(s);
  cnrtNotifierDestroy(e);
  return x;
}
