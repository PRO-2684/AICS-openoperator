#include <bang.h>
#include <bang_device_functions_decls.h>
#include <cnrt.h>
#include <cstdint>
#include <framework/core/MLUStream.h>
#include <stdio.h>
#include <sys/resource.h>
#include <torch/extension.h>

#define E0 4000000
#define E1 131072
#define E2 32

__mlu_entry__ void k0(half *__restrict__ x) {
  __nram__ half a[E1];
  half *o = a;
  half *i = a + 65536;
  for (int p = taskId * E1; p < E0; p += E1 * E2) {
    int n = E0 - p;
    if (n > E1) {
      n = E1;
    }
    int r = n >> 15;
    int t = n - (r << 15);
    if (r > 0) {
      __memcpy_async(i, x + p, 65536, GDRAM2NRAM);
      __asm__ volatile("sync;");
    }
    if (r > 1) {
      __memcpy_async(i + 32768, x + p + 32768, 65536, GDRAM2NRAM);
      __bang_active_gelu(o, i, 32768);
      __asm__ volatile("sync;");
    }
    for (int q = 0; q < r - 2; ++q) {
      int c = (q & 1) << 15;
      int d = ((q + 1) & 1) << 15;
      __memcpy_async(x + p + (q << 15), o + c, 65536, NRAM2GDRAM);
      __memcpy_async(i + c, x + p + ((q + 2) << 15), 65536, GDRAM2NRAM);
      __bang_active_gelu(o + d, i + d, 32768);
      __asm__ volatile("sync;");
    }
    if (r > 1) {
      __memcpy_async(x + p + ((r - 2) << 15), o + (((r - 2) & 1) << 15), 65536,
                     NRAM2GDRAM);
    }
    if (t > 0) {
      __memcpy_async(i + ((r & 1) << 15), x + p + (r << 15), t * sizeof(half),
                     GDRAM2NRAM);
    }
    if (r > 0) {
      __bang_active_gelu(o + (((r - 1) & 1) << 15), i + (((r - 1) & 1) << 15),
                         32768);
    }
    __asm__ volatile("sync;");
    if (r > 0) {
      __memcpy_async(x + p + ((r - 1) << 15), o + (((r - 1) & 1) << 15), 65536,
                     NRAM2GDRAM);
    }
    if (t > 0) {
      int m = (t + 63) & ~63;
      int c = (r & 1) << 15;
      if (m > t) {
        __bang_write_value(i + c + t, m - t, (half)0.0f);
      }
      __bang_active_gelu(o + c, i + c, m);
      __asm__ volatile("sync;");
      __memcpy_async(x + p + (r << 15), o + c, t * sizeof(half), NRAM2GDRAM);
    }
  }
}

torch::Tensor bang_func(torch::Tensor x) {
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t dim = {E2, 1, 1};
  cnrtNotifier_t s;
  cnrtNotifier_t e;
  cnrtNotifierCreate(&s);
  cnrtNotifierCreate(&e);
  cnrtPlaceNotifier(s, queue);
  k0<<<dim, cnrtFuncTypeBlock, queue>>>(
      reinterpret_cast<half *>(x.unsafeGetTensorImpl()->mutable_data()));
  cnrtPlaceNotifier(e, queue);
  cnrtQueueSync(queue);
  float us = 0.0f;
  cnrtNotifierDuration(s, e, &us);
  fprintf(stdout, "KERNEL_US op=030 us=%.3f\n", us);
  fflush(stdout);
  cnrtNotifierDestroy(s);
  cnrtNotifierDestroy(e);
  return x;
}
