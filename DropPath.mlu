#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

// Task: 099 099_DropPath
// Category: fused
// Difficulty: medium
// DType: float16
// Description: 实现一个 BangC 算子，实现 DropPath（随机深度）功能，在训练模式下按样本维度随机丢弃部分输入数据并对剩余部分进行缩放。输入包括形状为 `[batch, ...]` 的张量 `x` 以及表示丢弃概率的浮点数标量 `drop_prob`；输出结果与 `x` 形状一致。
// Wrapper: torch::Tensor bang_func(torch::Tensor x, double drop_prob);

__mlu_entry__ void k0(const half *__restrict__ x, half *__restrict__ y,
                      int sample_elems, float scale) {
  __nram__ half buf[65536];
  int tid = taskId;
  if (tid >= 32) {
    return;
  }
  int base = tid * sample_elems;
  for (int p = 0; p < sample_elems; p += 65536) {
    int n = sample_elems - p;
    if (n > 65536) {
      n = 65536;
    }
    __memcpy(buf, x + base + p, n * sizeof(half), GDRAM2NRAM);
    __bang_mul_scalar(buf, buf, (half)scale, n);
    __memcpy(y + base + p, buf, n * sizeof(half), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor x, double drop_prob) {
  auto y = torch::empty_like(x);
  float scale = 1.0f / (1.0f - (float)drop_prob);
  int sample_elems = (int)(x.numel() / x.size(0));
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t grid = {32, 1, 1};
  k0<<<grid, cnrtFuncTypeBlock, queue>>>(
      reinterpret_cast<const half *>(x.data_ptr<at::Half>()),
      reinterpret_cast<half *>(y.data_ptr<at::Half>()), sample_elems, scale);
  return y;
}
