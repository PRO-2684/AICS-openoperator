#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

#pragma bang walign(64)

#define E0 32
#define E1 8192
#define E2 16384
#define ZT 131072
#define ZO 524288

__mlu_entry__ void kz(float *__restrict__ y) {
  __nram__ float z[ZT];
  __bang_write_zero(z, ZT);
  for (int p = taskId * ZT; p < ZO; p += taskDim * ZT) {
    __memcpy(y + p, z, ZT * sizeof(float), NRAM2GDRAM);
  }
}

__mlu_entry__ void k0(const half *__restrict__ a, const half *__restrict__ b,
                      float *__restrict__ y) {
  __nram__ half x[E1];
  __nram__ half r[E1];
  __nram__ half z[E1];
  __nram__ float f[E2];
  __wram__ half w[E1];

  int p = taskId;
  __memcpy(x, a + p * E1, E1 * sizeof(half), GDRAM2NRAM);
  __memcpy(z, b + p * E1, E1 * sizeof(half), GDRAM2NRAM);
  __bang_reshape_filter(r, z, 128, 1, 1, 64);
  __memcpy(w, r, E1 * sizeof(half), NRAM2WRAM);
  __bang_matmul(f, x, w, 128, 64, 128);
  __memcpy(y + p * E2, f, E2 * sizeof(float), NRAM2GDRAM);
}

torch::Tensor bang_func(torch::Tensor A, torch::Tensor B) {
  auto y = torch::empty({4, 8, 128, 128}, A.options().dtype(torch::kFloat32));
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t d = {4, 8, 1};
  cnrtNotifier_t st;
  cnrtNotifier_t en;
  cnrtNotifierCreate(&st);
  cnrtNotifierCreate(&en);
  cnrtPlaceNotifier(st, queue);
  kz<<<d, cnrtFuncTypeBlock, queue>>>(y.data_ptr<float>());
  cnrtPlaceNotifier(en, queue);
  cnrtQueueSync(queue);
  float us = 0.0f;
  cnrtNotifierDuration(st, en, &us);
  fprintf(stdout, "KERNEL_US op=090 us=%.3f\n", us);
  fflush(stdout);
  cnrtNotifierDestroy(st);
  cnrtNotifierDestroy(en);
  return y;
}
