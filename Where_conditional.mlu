#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <vector>

__mlu_entry__ void empty_kernel_Where_conditional() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

torch::Tensor bang_func(torch::Tensor condition, torch::Tensor x, torch::Tensor y) {
  (void)condition;
  (void)x;
  (void)y;
  empty_kernel_Where_conditional<<<launch_dim, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>();
  return condition;
}
