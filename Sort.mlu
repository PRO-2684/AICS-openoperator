#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <vector>

__mlu_entry__ void empty_kernel_Sort() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

torch::Tensor bang_func(torch::Tensor x, int dim, bool descending) {
  (void)x;
  (void)dim;
  (void)descending;
  empty_kernel_Sort<<<launch_dim, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>();
  return x;
}
