#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

#define E0 16

__mlu_entry__ void k0(const half *__restrict__ x, half *__restrict__ y) {
  __nram__ half t[8192];
  __nram__ half a[8448];
  __nram__ half b[4096];
  __bang_write_value(a, 8448, (half)-65504.0f);
  for (int r = taskId; r < E0; r += taskDim) {
    int base = r << 6;
    __memcpy(t, x + base * 128, 8192 * sizeof(half), GDRAM2NRAM);
    __memcpy(a + 2, t, 128 * sizeof(half), NRAM2NRAM, 132 * sizeof(half),
             128 * sizeof(half), 63);
    __bang_maxpool(b, a, 1, 64, 132, 1, 4, 2, 1, 1, 3, 1, 1);
    __memcpy(y + base * 62, b, 3968 * sizeof(half), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor x, int kernel_size, int stride,
                        int padding, int dilation, bool return_indices) {
  auto y = torch::empty({16, 64, 62}, x.options());
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t g = {4, 8, 1};
  k0<<<g, cnrtFuncTypeUnion1, queue>>>(
      reinterpret_cast<const half *>(x.data_ptr<at::Half>()),
      reinterpret_cast<half *>(y.data_ptr<at::Half>()));
  return y;
}
