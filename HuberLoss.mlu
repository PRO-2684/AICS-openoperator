#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <stdio.h>
#include <torch/extension.h>

#define E0 524288
#define E1 32768

__mlu_entry__ void k0(const half *__restrict__ x, const half *__restrict__ t,
                      float *__restrict__ tmp) {
  __nram__ half a[E1];
  __nram__ half b[E1];
  __nram__ float fa[E1];
  __nram__ float fb[E1];
  __nram__ float u[E1];
  __nram__ float r[E1];
  float s = 0.0f;
  for (int base = taskId * E1; base < E0; base += taskDim * E1) {
    __memcpy(a, x + base, E1 * sizeof(half), GDRAM2NRAM);
    __memcpy(b, t + base, E1 * sizeof(half), GDRAM2NRAM);
    __bang_half2float(fa, a, E1);
    __bang_half2float(fb, b, E1);
    __bang_sub(fa, fa, fb, E1);
    __bang_abs(fa, fa, E1);
    __bang_sub_scalar(u, fa, 1.0f, E1);
    __bang_relu(u, u, E1);
    __bang_sub(fa, fa, u, E1);
    __bang_mul(fa, fa, fa, E1);
    __bang_mul_scalar(fa, fa, 0.5f, E1);
    __bang_add(fa, fa, u, E1);
    __bang_reduce_sum(r, fa, E1);
    s += r[0];
  }
  tmp[taskId] = s;
}

__mlu_entry__ void k1(const float *__restrict__ tmp, half *__restrict__ y) {
  __nram__ float a[32];
  __memcpy(a, tmp, 32 * sizeof(float), GDRAM2NRAM);
  float s = 0.0f;
  for (int i = 0; i < 32; ++i) {
    s += a[i];
  }
  *y = (half)(s * 0.0000019073486328125f);
}

torch::Tensor bang_func(torch::Tensor predictions, torch::Tensor targets) {
  auto y = torch::empty({}, predictions.options());
  auto tmp = torch::empty({32}, predictions.options().dtype(torch::kFloat32));
  cnrtQueue_t queue = torch_mlu::getCurMLUStream();
  cnrtDim3_t dim = {32, 1, 1};
  cnrtDim3_t dim1 = {1, 1, 1};
  cnrtNotifier_t s;
  cnrtNotifier_t e;
  cnrtNotifierCreate(&s);
  cnrtNotifierCreate(&e);
  cnrtPlaceNotifier(s, queue);
  k0<<<dim, cnrtFuncTypeBlock, queue>>>(
      static_cast<const half *>(predictions.unsafeGetTensorImpl()->mutable_data()),
      static_cast<const half *>(targets.unsafeGetTensorImpl()->mutable_data()),
      static_cast<float *>(tmp.unsafeGetTensorImpl()->mutable_data()));
  k1<<<dim1, cnrtFuncTypeBlock, queue>>>(
      static_cast<const float *>(tmp.unsafeGetTensorImpl()->mutable_data()),
      static_cast<half *>(y.unsafeGetTensorImpl()->mutable_data()));
  cnrtPlaceNotifier(e, queue);
  cnrtQueueSync(queue);
  float us = 0.0f;
  cnrtNotifierDuration(s, e, &us);
  fprintf(stdout, "KERNEL_US op=045 us=%.3f\n", us);
  fflush(stdout);
  cnrtNotifierDestroy(s);
  cnrtNotifierDestroy(e);
  return y;
}
