__mlu_entry__ void empty_kernel_upsample_bilinear2d_out_frame() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

torch::Tensor bang_func(torch::Tensor input, int out_h, int out_w, bool align_corners) {
  (void)input;
  (void)out_h;
  (void)out_w;
