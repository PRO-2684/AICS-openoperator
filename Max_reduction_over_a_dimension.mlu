#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

__mlu_entry__ void k0(const half *__restrict__ x, half *__restrict__ y) {
  __nram__ half a[16384];
  __nram__ half b[128];
  for (int t = taskId; t < 64; t += taskDim) {
    int n = t >> 2;
    int h = t & 3;
    const half *src = x + n * 65536 + h * 64;
    __memcpy(a, src, 64 * sizeof(half), GDRAM2NRAM, 64 * sizeof(half),
             256 * sizeof(half), 255);
    __bang_maxpool_value_index(b, a, 1, 256, 64, 256, 1, 1, 1,
                               64 * sizeof(half));
    __memcpy(y + n * 256 + h * 64, b, 64 * sizeof(half), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor x, int dim) {
  (void)dim;
  auto y = torch::empty({16, 256}, x.options());
  cnrtDim3_t d = {32, 1, 1};
  k0<<<d, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>(
      reinterpret_cast<const half *>(x.data_ptr<at::Half>()),
      reinterpret_cast<half *>(y.data_ptr<at::Half>()));
  return y;
}
