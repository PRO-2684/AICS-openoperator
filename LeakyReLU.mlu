#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

#define E0 262144
#define E1 4096

__mlu_entry__ void k0(const float *__restrict__ x, float *__restrict__ y,
                      float s) {
  __nram__ float a[E1];
  __nram__ float b[E1];
  for (int p = taskId * E1; p < E0; p += taskDim * E1) {
    __memcpy(a, x + p, E1 * sizeof(float), GDRAM2NRAM);
    __bang_active_relu(b, a, E1);
    __bang_sub(a, a, b, E1);
    __bang_mul_scalar(a, a, s, E1);
    __bang_add(a, a, b, E1);
    __memcpy(y + p, a, E1 * sizeof(float), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor x, double s) {
  auto y = torch::empty_like(x);
  cnrtDim3_t d = {32, 1, 1};
  k0<<<d, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>(
      x.data_ptr<float>(), y.data_ptr<float>(), (float)s);
  return y;
}
