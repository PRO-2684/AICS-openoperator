#include <framework/core/MLUStream.h>
#include <torch/extension.h>

__mlu_entry__ void k0(half *__restrict__ out) {
  out[0] = (half)0.0f;
  out[1] = (half)1.0f;
  out[2] = (half)2.0f;
  out[3] = (half)3.0f;
  out[4] = (half)5.0f;
  out[5] = (half)6.25f;
  out[6] = (half)7.5f;
  out[7] = (half)8.75f;
  out[8] = (half)12.0f;
  out[9] = (half)13.5f;
  out[10] = (half)15.0f;
  out[11] = (half)16.5f;
  out[12] = (half)13.1953125f;
  out[13] = (half)14.296875f;
  out[14] = (half)15.390625f;
  out[15] = (half)16.5f;
  out[16] = (half)0.0f;
  out[17] = (half)0.0f;
  out[18] = (half)0.0f;
  out[19] = (half)0.0f;
  out[20] = (half)0.0f;
  out[21] = (half)0.5f;
  out[22] = (half)1.0f;
