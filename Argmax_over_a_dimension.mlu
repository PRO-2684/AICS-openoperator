#define A_DECL(i) __nram__ half q##i[64]
#define A_RUN(i) __bang_argmax(q##i, b + (j + i) * E1, E1)
#define A_OUT(i) o[j + i] = (int16_t)((uint16_t *)q##i)[1]

__mlu_entry__ void k19(const half *__restrict__ x, int16_t *__restrict__ y) {
  int t = taskId;
  int n = t >> 1;
  int p = t & 1;
  int col = p << 7;
  __nram__ half a[32768];
  __nram__ half b[32768];
  A_DECL(0);
