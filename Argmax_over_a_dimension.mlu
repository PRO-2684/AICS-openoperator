__mlu_entry__ void k16(const half *__restrict__ x, int16_t *__restrict__ y) {
  int t = taskId;
  int n = t >> 1;
  int p = t & 1;
  int col = p << 7;
  __nram__ half a[32768];
  __nram__ half b[32768];
  __nram__ half r0[64];
  __nram__ half r1[64];
  __nram__ half r2[64];
