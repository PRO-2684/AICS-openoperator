__mlu_entry__ void k16(const half *__restrict__ x, int16_t *__restrict__ y) {
  int t = taskId;
  int n = t >> 1;
  int p = t & 1;
  int col = p << 7;
  __nram__ half a[32768];
  __nram__ half b[32768];
  __nram__ half r0[64];
  __nram__ half r1[64];
  __nram__ half r2[64];
  __nram__ half r3[64];
  __nram__ int16_t o[128];
  __memcpy(a, x + n * 65536 + col, 256, GDRAM2NRAM, 256, 512, 255);
  __bang_transpose(b, a, E1, 128);
  for (int j = 0; j < 128; j += 4) {
    __bang_argmax(r0, b + j * E1, E1);
    __bang_argmax(r1, b + (j + 1) * E1, E1);
    __bang_argmax(r2, b + (j + 2) * E1, E1);
    __bang_argmax(r3, b + (j + 3) * E1, E1);
    o[j] = (int16_t)((uint16_t *)r0)[1];
    o[j + 1] = (int16_t)((uint16_t *)r1)[1];
    o[j + 2] = (int16_t)((uint16_t *)r2)[1];
    o[j + 3] = (int16_t)((uint16_t *)r3)[1];
  }
  __memcpy(y + n * E1 + col, o, 128 * sizeof(int16_t), NRAM2GDRAM);
}

torch::Tensor bang_func(torch::Tensor x, int dim) {
  (void)dim;
  static torch::Tensor y;
  if (!y.defined())
    y = torch::empty({16, 256}, x.options().dtype(torch::kInt16));
  else
    y.resize_({16, 256});
  cnrtDim3_t d = {4, 8, 1};
  k16<<<d, cnrtFuncTypeUnion1, torch_mlu::getCurMLUStream()>>>(
      reinterpret_cast<const half *>(x.data_ptr<at::Half>()),
      y.data_ptr<int16_t>());
  return y;
}
