}

__mlu_entry__ void k5(const half *__restrict__ x, int64_t *__restrict__ y) {
  int t = taskId;
  int g = t >> 2;
  int p = t & 3;
  int col = p << 6;
  __nram__ half a[65536];
  __nram__ half b[65536];
  __nram__ half r[64];
  for (int n = g; n < 16; n += 8) {
    __memcpy(a, x + n * 65536, 65536 * sizeof(half), GDRAM2NRAM);
    __bang_transpose(b, a, E1, E1);
    for (int j = 0; j < 64; ++j) {
      __bang_argmax(r, b + (col + j) * E1, E1);
      y[n * E1 + col + j] = (int64_t)((uint16_t *)r)[1];
    }
  }
}

__mlu_entry__ void k6(const half *__restrict__ x, int64_t *__restrict__ y) {
  int n = taskId;
  if (n >= 16)
    return;
  __nram__ half mv[256];
  __nram__ half row[256];
  __nram__ half ih[256];
  __nram__ half m[256];
  __nram__ half t[256];

  const half *base = x + n * 65536;
  __memcpy(mv, base, 256 * sizeof(half), GDRAM2NRAM);
  __bang_write_zero(ih, 256);

  for (int i = 1; i < 256; ++i) {
    __memcpy(row, base + i * 256, 256 * sizeof(half), GDRAM2NRAM);
    __bang_gt(m, row, mv, 256);
    __bang_maximum(mv, row, mv, 256);
    __bang_mul_scalar(t, m, (half)i, 256);
    __bang_mul_scalar(m, m, (half)-1.0f, 256);
    __bang_add_scalar(m, m, (half)1.0f, 256);
    __bang_mul(ih, ih, m, 256);
    __bang_add(ih, ih, t, 256);
  }

  for (int j = 0; j < 256; ++j) {
    y[n * E1 + j] = (int64_t)((float)ih[j]);
  }
}

__mlu_entry__ void k7(const half *__restrict__ x, int64_t *__restrict__ y) {
  int t = taskId;
  int n = t >> 1;
  int p = t & 1;
  int col = p << 7;
  __nram__ half a[32768];
  __nram__ half b[32768];
  __nram__ half r[64];
  __nram__ int64_t o[128];
  __memcpy(a, x + n * 65536 + col, 256, GDRAM2NRAM, 256, 512, 255);
  __bang_transpose(b, a, E1, 128);
  for (int j = 0; j < 128; ++j) {
    __bang_argmax(r, b + j * E1, E1);
    o[j] = (int64_t)((uint16_t *)r)[1];
  }
  __memcpy(y + n * E1 + col, o, 128 * sizeof(int64_t), NRAM2GDRAM);
}

