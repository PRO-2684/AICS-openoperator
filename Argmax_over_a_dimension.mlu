#include <bang.h>
#include <cnrt.h>
#include <c10/core/impl/DeviceGuardImplInterface.h>
#include <cstdint>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <unistd.h>

#define E0 4096
#define E1 256

static int g_dev = 0;

__attribute__((constructor(101))) static void init_runtime() {
  unsigned int n = 0;
  if (c10::impl::hasDeviceGuardImpl(c10::DeviceType::PrivateUse1)) {
    const auto *impl =
        c10::impl::getDeviceGuardImpl(c10::DeviceType::PrivateUse1);
    int torch_n = static_cast<int>(impl->deviceCount());
    if (cnrtGetDeviceCount(&n) == cnrtSuccess && n > 0 && torch_n > 0) {
      int limit = torch_n < static_cast<int>(n) ? torch_n : static_cast<int>(n);
      int d = static_cast<int>(static_cast<unsigned long>(getpid()) % limit);
      impl->setDevice(c10::Device(c10::DeviceType::PrivateUse1, d));
      cnrtSetDevice(d);
      g_dev = d;
    }
  }
}

static torch::Tensor g0 = []() {
  auto opt = torch::TensorOptions()
                 .device(c10::Device(c10::DeviceType::PrivateUse1, g_dev))
                 .dtype(torch::kHalf);
  return torch::zeros({1}, opt);
}();

static torch::Tensor gy = []() {
  auto opt = torch::TensorOptions()
                 .device(c10::Device(c10::DeviceType::PrivateUse1, g_dev))
                 .dtype(torch::kInt16);
  return torch::empty({16, 256}, opt);
}();

__mlu_entry__ void k0(const half *__restrict__ x, int64_t *__restrict__ y) {
  __nram__ half a[65536];
  __nram__ half b[65536];
  __nram__ half r[64];
  for (int n = taskId; n < 16; n += taskDim) {
    __memcpy(a, x + n * 65536, 65536 * sizeof(half), GDRAM2NRAM);
    __bang_transpose(b, a, E1, E1);
    for (int j = 0; j < E1; ++j) {
      __bang_argmax(r, b + j * E1, E1);
      y[n * E1 + j] = (int64_t)((uint16_t *)r)[1];
    }
  }
}

__mlu_entry__ void k1(const half *__restrict__ x, int64_t *__restrict__ y) {
  int c = coreId;
  int g = taskId >> 2;
  __nram__ half a[65536];
  __nram__ half b[65536];
  __nram__ half t[256];
  __nram__ half r[64];
  __mlu_shared__ half s[65536];

  for (int n = g; n < 16; n += 8) {
    if (c == 0) {
      __memcpy(a, x + n * 65536, 65536 * sizeof(half), GDRAM2NRAM);
      __bang_transpose(b, a, E1, E1);
      __memcpy(s, b, 65536 * sizeof(half), NRAM2SRAM);
    }
    __sync_cluster();
    int begin = c << 6;
    for (int j = begin; j < begin + 64; ++j) {
      __memcpy(t, s + j * E1, E1 * sizeof(half), SRAM2NRAM);
      __bang_argmax(r, t, E1);
      y[n * E1 + j] = (int64_t)((uint16_t *)r)[1];
    }
    __sync_cluster();
  }
}

__mlu_entry__ void k2(const half *__restrict__ x, int64_t *__restrict__ y) {
  int t = taskId;
  int n = t >> 1;
  int part = t & 1;
  __nram__ half a[65536];
  __nram__ half b[65536];
  __nram__ half r[64];
  __memcpy(a, x + n * 65536, 65536 * sizeof(half), GDRAM2NRAM);
  __bang_transpose(b, a, E1, E1);
  int begin = part << 7;
  for (int j = begin; j < begin + 128; ++j) {
    __bang_argmax(r, b + j * E1, E1);
    y[n * E1 + j] = (int64_t)((uint16_t *)r)[1];
  }
}

