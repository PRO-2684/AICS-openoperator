    __sync_cluster();
    if (c < 4) {
      __memcpy(r, s, E1 * sizeof(float), SRAM2NRAM);
      float d = s[E1];
      for (int ii = 0; ii < 16; ++ii) {
        int i = r0 + ii;
        if (i <= j)
