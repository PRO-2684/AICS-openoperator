  __nram__ float b[E3];
  __nram__ float r[E1];
  int n = taskIdY;
  int c = coreId;
  int r0 = c * 16;
  if (c < 4) {
    int o = c * E3;
    __memcpy(a, x + n * E2 + o, E3 * sizeof(half), GDRAM2NRAM);
