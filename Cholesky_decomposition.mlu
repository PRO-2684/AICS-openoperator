        float v = b[ii * E1 + j];
        int k = 0;
        int m = j;
        for (; k + 3 < m; k += 4) {
          v -= b[ii * E1 + k] * r[k] +
               b[ii * E1 + k + 1] * r[k + 1] +
               b[ii * E1 + k + 2] * r[k + 2] +
               b[ii * E1 + k + 3] * r[k + 3];
