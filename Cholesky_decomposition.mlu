static S0 s0;

__mlu_entry__ void k0(const half *__restrict__ x, half *__restrict__ y) {
  __mlu_shared__ float s[E2];
  __nram__ half a[E3];
  __nram__ float b[E3];
  int n = taskIdY;
  int c = coreId;
  if (c < 4) {
    int o = c * E3;
    __memcpy(a, x + n * E2 + o, E3 * sizeof(half), GDRAM2NRAM);
    __bang_half2float(b, a, E3);
    __memcpy(s + o, b, E3 * sizeof(float), NRAM2SRAM);
  }
  __sync_cluster();
  for (int j = 0; j < E1; ++j) {
    if (c == 0) {
      float v = s[j * E1 + j];
      int k = 0;
      int m = j;
      for (; k + 3 < m; k += 4) {
        float v0 = s[j * E1 + k];
        float v1 = s[j * E1 + k + 1];
        float v2 = s[j * E1 + k + 2];
        float v3 = s[j * E1 + k + 3];
        v = fmaf(-v0, v0, v);
        v = fmaf(-v1, v1, v);
        v = fmaf(-v2, v2, v);
        v = fmaf(-v3, v3, v);
      }
      for (; k < m; ++k)
        v = fmaf(-s[j * E1 + k], s[j * E1 + k], v);
      s[j * E1 + j] = sqrtf(v);
    }
    __sync_cluster();
    if (c < 4) {
      float d = s[j * E1 + j];
      for (int i = j + 1 + c; i < E1; i += 4) {
        float v = s[i * E1 + j];
        int k = 0;
        int m = j;
        for (; k + 3 < m; k += 4) {
          v = fmaf(-s[i * E1 + k], s[j * E1 + k], v);
          v = fmaf(-s[i * E1 + k + 1], s[j * E1 + k + 1], v);
          v = fmaf(-s[i * E1 + k + 2], s[j * E1 + k + 2], v);
          v = fmaf(-s[i * E1 + k + 3], s[j * E1 + k + 3], v);
        }
        for (; k < m; ++k)
          v = fmaf(-s[i * E1 + k], s[j * E1 + k], v);
        s[i * E1 + j] = v / d;
      }
    }
    __sync_cluster();
  }
  if (c < 4) {
    int o = c * E3;
    __memcpy(b, s + o, E3 * sizeof(float), SRAM2NRAM);
    int r0 = c * 16;
    for (int i = 0; i < 16; ++i) {
      int g = r0 + i;
      if (g + 1 < E1)
        __bang_write_value(b + i * E1 + g + 1, E1 - g - 1, 0.0f);
    }
    __bang_float2half_rn(a, b, E3);
    __memcpy(y + n * E2 + o, a, E3 * sizeof(half), NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor A) {
  static torch::Tensor y;
  if (!y.defined())
    y = torch::empty({E0, E1, E1}, A.options());
  else
    y.resize_({E0, E1, E1});
  cnrtDim3_t d = {4, E0, 1};
  k0<<<d, cnrtFuncTypeUnion1, torch_mlu::getCurMLUStream()>>>(
      reinterpret_cast<const half *>(A.data_ptr<at::Half>()),
      reinterpret_cast<half *>(y.data_ptr<at::Half>()));
  return y;
}
