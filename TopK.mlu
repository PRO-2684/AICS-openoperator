#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <vector>

__mlu_entry__ void empty_kernel_TopK() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

std::vector<torch::Tensor> bang_func(torch::Tensor x, int k, int dim) {
  (void)x;
  (void)k;
  (void)dim;
  empty_kernel_TopK<<<launch_dim, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>();
  return {x, x};
}
