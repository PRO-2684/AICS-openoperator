#include <bang.h>
#include <cnrt.h>
#include <torch/extension.h>

torch::Tensor bang_func(torch::Tensor x, torch::Tensor w, int c0, int c1,
                        int k, int s, int p, int o, int g, bool b) {
  (void)w;
  (void)c0;
  (void)c1;
  (void)k;
  (void)s;
  (void)p;
  (void)o;
  (void)g;
  (void)b;
  return torch::empty({16, 64, 130, 258}, x.options());
}
