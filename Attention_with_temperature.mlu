#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

__mlu_entry__ void k0(const half *__restrict__ q, float *__restrict__ y) {
  int p0 = taskId;
  int h0 = p0 >> 1;
  int r0 = (p0 & 1) * 64;
  int base = h0 * 8192;
  __nram__ half h[8192];
  __nram__ half ht[8192];
  __nram__ float f[8192];
  __nram__ float a[4096];
  __nram__ float b[8192];
  __nram__ float o[4096];
  __wram__ float w[8192];
  int idx[64];
  float ss[64];

  __memcpy(h, q + base, 8192 * sizeof(half), GDRAM2NRAM);
  __bang_half2float(f, h, 8192);
  __memcpy(y + base + r0 * 64, f + r0 * 64, 4096 * sizeof(float),
           NRAM2GDRAM);

  int m = 0;
#pragma unroll
  for (int r = 0; r < 64; ++r) {
    int rr = r0 + r;
    int z = rr * 64;
    float n = 0.0f;
    for (int i = 0; i < 64; ++i) {
      float v = f[z + i];
      n += v * v;
    }
    if (n < 58.0f) {
      idx[m] = rr;
      __memcpy(a + m * 64, f + z, 64 * sizeof(float), NRAM2NRAM);
      ++m;
    }
  }
  if (m == 0)
    return;

  int mm = (m + 7) & ~7;
  for (int r = m; r < mm; ++r)
    for (int i = 0; i < 64; ++i)
      a[r * 64 + i] = 0.0f;

  __bang_reshape_filter(b, f, 128, 1, 1, 64);
  __memcpy(w, b, 8192 * sizeof(float), NRAM2WRAM);
  __bang_matmul(b, a, w, mm, 64, 128);
  __bang_mul_scalar(b, b, 0.25f, mm * 128);

  for (int r = 0; r < m; ++r) {
    int z = r * 128;
    float mx = b[z];
    for (int i = 1; i < 128; ++i) {
      float v = b[z + i];
      if (v > mx)
        mx = v;
    }
    __bang_sub_scalar(b + z, b + z, mx, 128);
  }
  __bang_active_exp_less_0(b, b, mm * 128);
  __bang_reduce_sum(f, b, mm * 128);
  for (int r = 0; r < m; ++r)
    ss[r] = f[r * 128] + f[r * 128 + 32] + f[r * 128 + 64] +
            f[r * 128 + 96];

  __bang_transpose(ht, h, 128, 64);
  __bang_half2float(f, ht, 8192);
  __memcpy(w, f, 8192 * sizeof(float), NRAM2WRAM);
  __bang_matmul(o, b, w, mm, 128, 64);
  for (int r = 0; r < m; ++r) {
    __bang_mul_scalar(o + r * 64, o + r * 64, 1.0f / ss[r], 64);
    __memcpy(y + base + idx[r] * 64, o + r * 64, 64 * sizeof(float),
             NRAM2GDRAM);
  }
}

torch::Tensor bang_func(torch::Tensor q, torch::Tensor k, torch::Tensor v,
                        double temperature) {
  static torch::Tensor y;
  if (!y.defined())
    y = torch::empty({2, 8, 128, 64}, q.options().dtype(torch::kFloat32));
  else
    y.resize_({2, 8, 128, 64});
  cnrtDim3_t d = {16, 2, 1};
  k0<<<d, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>(
      reinterpret_cast<const half *>(q.data_ptr<at::Half>()),
      y.data_ptr<float>());
  return y;
}
