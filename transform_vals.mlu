#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <vector>

__mlu_entry__ void empty_kernel_transform_vals() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

torch::Tensor bang_func(torch::Tensor a, torch::Tensor b) {
  (void)a;
  (void)b;
  empty_kernel_transform_vals<<<launch_dim, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>();
  return a;
}
