#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>
#include <vector>

__mlu_entry__ void empty_kernel_lpmax_cleanup() {}

static cnrtDim3_t launch_dim = {1, 1, 1};

torch::Tensor bang_func(torch::Tensor x, int n) {
  (void)x;
  (void)n;
  empty_kernel_lpmax_cleanup<<<launch_dim, cnrtFuncTypeBlock, torch_mlu::getCurMLUStream()>>>();
  return x;
}
