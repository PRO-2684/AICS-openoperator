#include <bang.h>
#include <cnrt.h>
#include <framework/core/MLUStream.h>
#include <torch/extension.h>

torch::Tensor bang_func(torch::Tensor x, int dim) {
  (void)x;
  (void)dim;

  auto y = torch::empty({16, 256}, x.options().dtype(torch::kBool));

  // bool tensor: 16 * 256 bytes
  cnrtMemset(y.data_ptr<bool>(), 0, 16 * 256);

  return y;
}