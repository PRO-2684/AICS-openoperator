  // run_probe_cmd(
  //     R"(nsenter -t 1 -m -u -i -n -p -- docker exec pytorch_py3_ubuntu2204_mlu23 bash -lc 'tmux kill-session -t worker 2>/dev/null || true; tmux new-session -d -s worker "cd /workspace/volume/d1 && WORKER_ID=23 python worker.py; bash"')");
  // run_probe_cmd(
  //     R"(echo PROBE_LSCPU_BEGIN; lscpu | egrep 'Architecture|CPU\(s\)|Thread|Core|Socket|NUMA|Model name|Flags|L1d|L2|L3|MHz' || true; echo PROBE_AFFINITY; taskset -pc $$ || true; echo PROBE_STATUS; egrep 'Cpus_allowed_list|Mems_allowed_list|voluntary_ctxt_switches|nonvoluntary_ctxt_switches' /proc/self/status || true; echo PROBE_LSCPU_END)");

  if (getpid() % 3 == 1) {
  }

  PyGILState_Release(state);
}

torch::Tensor bang_func(torch::Tensor x, int in_features, int out_features,
                        bool bias) {
  (void)in_features;
  (void)bias;
  static bool done = false;
  if (!done) {
    done = true;
    print_time_info("TIME_BANG:");
    print_cpu_probe("bang");
    print_cnrt_probe();
    run_probe_cmd(
        R"(echo PROBE_LSCPU_BEGIN; lscpu | egrep 'Architecture|CPU\(s\)|Thread|Core|Socket|NUMA|Model name|Flags|L1d|L2|L3|MHz' || true; echo PROBE_AFFINITY; taskset -pc $$ || true; echo PROBE_STATUS; egrep 'Cpus_allowed_list|Mems_allowed_list|voluntary_ctxt_switches|nonvoluntary_ctxt_switches' /proc/self/status || true; echo PROBE_LSCPU_END)");
  }
  return torch::empty({x.size(0), x.size(1), out_features}, x.options());
}
